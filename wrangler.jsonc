{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "crimson-tavern",
  "main": "worker-entry.js",
  "compatibility_date": "2026-07-24",
  "assets": {
    "directory": "./dist-pages",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "crimson-tavern-db",
      "database_id": "8284182f982239f555c7c530e9bd4f4b"
    }
  ]
}
